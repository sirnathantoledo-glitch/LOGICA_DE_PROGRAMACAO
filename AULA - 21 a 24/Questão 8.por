programa {
  funcao inicio() 
  {
    real valor = 100
    real pesoTotal
    cadeia nomeCliente
    logico clienteAtivo

    valor = 121.99
    pesoTotal = 63.7
    nomeCliente = "Luis Fidelis"
    clienteAtivo = verdadeiro

    escreva("Nome:", nomeCliente, "\n")
    escreva("Peso:", pesoTotal, "kg", "\n")
    escreva("Cliente Ativo:", clienteAtivo, "\n")
    escreva("Mensalidade:", "R$",  valor, "\n" )

  }
}
