programa {
  funcao inicio() 
  {
  cadeia nomeProduto
  inteiro codigo
  real preco
  logico disponivel

  nomeProduto = "Camiseta"
  codigo = 03311072026
  preco =  29.90
  disponivel = verdadeiro

  escreva("Nome:", nomeProduto, "\n")
  escreva("Codigo:", codigo, "\n")
  escreva("Preço:R$", preco, "\n")
  escreva("Disponivel:", disponivel, "\n")
  }
}
