programa {
  funcao inicio() 
  {
   inteiro numero1, numero2, numero3, equacao
  escreva("Digite o primeiro numero: ")
  leia(numero1)

  escreva("Digite o segundo numero: ")
  leia(numero2)

  escreva("Digite o terceiro numero: ")
  leia(numero3)

   equacao = numero1 * numero2 - numero3

   escreva("Resultado: ", equacao)
    
  }
}
