programa {
  funcao inicio() {
    inteiro numero
    escreva("Digite o numero: ")
    leia(numero)

    se (numero % 2 == 0 ){
      numero = numero +5
      escreva("Se o Numero for Par ", numero)
    }senao{
      numero = numero +8
      escreva("Se o Numero for Impar ", numero) 
    }
    


  }
}
