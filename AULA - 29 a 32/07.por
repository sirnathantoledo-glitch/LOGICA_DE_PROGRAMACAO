programa {
  funcao inicio() {
    inteiro numero1, numero2
    escreva("digite o primeiro numero:")
    leia(numero1)

    escreva("digite o segundo numero:")
    leia(numero2)
    
    se (numero1 > numero2){
      escreva("O Primeiro número é maior")
      }senao{ 
        escreva("O Segundo número é maior ou igual")
      }
    
    }

    

   
    
  }
}
