programa
{
    funcao inicio()
    {
        real n1, n2, media
        escreva("Digite valor da Primeira Nota: ") //Adcionado texto de entrada de dados de N1
        leia(n1)
        escreva("Digite valor da Segunda Nota: ") //Adcionado texto de entrada de dados de N2
        leia(n2)

        //media = (n1 + n2) / 3
        media = (n1 + n2) / 2
        
        escreva("Média: ", media)
    }
}