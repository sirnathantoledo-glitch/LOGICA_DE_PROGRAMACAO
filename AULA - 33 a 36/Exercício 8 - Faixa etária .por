programa
{
    funcao inicio()
    {
        inteiro idade
        escreva("Informe sua idade: ") //Adcionado texto para entrada de dados
        leia(idade)

        //se (idade >= 12 ou idade <= 17)
        se (idade >= 12 e idade <=17)
        {
            escreva("Adolescente")
        }
        senao
        {
            escreva("Não é adolescente")
        }
    }
}