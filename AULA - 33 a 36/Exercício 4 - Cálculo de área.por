programa
{
    funcao inicio()
    {
        //inteiro largura, altura
        real largura, altura, area
        
        
        escreva("Informe a largura: ") //Adcionado texto de entrada de largura
        leia(largura)
        escreva("Informe a altura: ") //Adcionado texto de entrada de altura
        leia(altura)

        area = largura * altura

        escreva("Área: ", area)
    }
}