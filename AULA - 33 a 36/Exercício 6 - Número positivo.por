programa
{
    funcao inicio()
    {
        inteiro numero
        escreva("Digite um numero: ") //Adcionado texto de entrada de dados
        leia(numero)

        //se (numero < 0){
        se (numero > 0){
            escreva("Numero positivo")
        }senao{
            escreva("Numero negativo") //Adcionado a condição
        }
    }
}