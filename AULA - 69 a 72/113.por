programa {
  funcao inicio() {
    inteiro numeros [5] = {1, 2, 3, 4, 5}

    escreva("Digite o primeiro numero: ")
    leia(numeros[0])

    escreva("Digite o Segundo numero: ")
    leia(numeros[1])

    escreva("Digite o terceiro numero: ")
    leia(numeros[2])

    escreva(numeros[0],"\n",numeros[1],"\n", numeros[2], "\n", numeros[3], "\n", numeros[4])
  }
}
