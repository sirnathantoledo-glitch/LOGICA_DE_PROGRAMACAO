programa {
  funcao inicio() {
    inteiro numeros [4] = {10, 20, 30, 40}
    inteiro soma, multiplicacao, diferenca
    

    escreva("Soma: ", numeros[0] + numeros[3], "\n")
    escreva("Multiplicação: ", numeros[1] * numeros[2], "\n")
    escreva("Diferença: ", numeros[2] - numeros [0], "\n")


    
    
  }
}
