programa {
  funcao inicio() {
    inteiro numeros [4] = {10, 20, 30, 40}
    inteiro soma, multiplicacao, diferenca
    soma = numeros[0] + numeros[3]
    multiplicacao = numeros[1] * numeros[2]
    diferenca = numeros[2] - numeros [0]

    escreva("Soma: ", soma, "\n")
    escreva("Multiplicação: ", multiplicacao, "\n")
    escreva("Diferença: ", diferenca, "\n")


    
    
  }
}
